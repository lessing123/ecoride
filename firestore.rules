rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users : lecture publique, écriture par soi-même seulement
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Trajets : lecture publique, création par auth, modification par conducteur
    match /trajets/{trajetId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.conducteurId == request.auth.uid ||
        // allow decrementing places by any authenticated user (reservation)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['placesDisponibles'])
      );
      allow delete: if request.auth != null && resource.data.conducteurId == request.auth.uid;
    }

    // Réservations : lecture par passager ou conducteur, création par auth
    match /reservations/{reservationId} {
      allow read: if request.auth != null && (
        resource.data.passagerId == request.auth.uid ||
        resource.data.conducteurId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.passagerId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.passagerId == request.auth.uid ||
        resource.data.conducteurId == request.auth.uid
      );
    }
  }
}
